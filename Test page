<!DOCTYPE html>
<html lang="hi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Hisab App</title>

<style>
body{
  font-family: Arial;
  background:#f2f2f2;
  margin:0;
  padding:10px;
}
h2{text-align:center}

.box{
  background:white;
  padding:15px;
  border-radius:10px;
  margin-bottom:15px;
}

input,button{
  width:100%;
  padding:10px;
  margin-top:8px;
  border-radius:6px;
}

button{
  background:#007bff;
  color:white;
  border:none;
}

.item{
  background:#eee;
  padding:8px;
  margin-top:5px;
  border-radius:5px;
  display:flex;
  justify-content:space-between;
}
</style>
</head>

<body>

<h2>🥛 Doodh & 💧 Pani Hisab</h2>

<div class="box">
<h3>Doodh</h3>
<input type="date" id="dDate">
<input type="number" id="dQty" placeholder="Liter">
<button onclick="add('doodh')">Add</button>
<div id="dList"></div>
</div>

<div class="box">
<h3>Pani</h3>
<input type="date" id="pDate">
<input type="number" id="pQty" placeholder="Liter">
<button onclick="add('pani')">Add</button>
<div id="pList"></div>
</div>

<div class="box">
<button onclick="exportData()">Export</button>
<input type="file" onchange="importData(event)">
</div>

<script>

// ===== STORAGE SAFE FUNCTION =====
function getStorage(){
  try{
    localStorage.setItem("test","1");
    localStorage.removeItem("test");
    return localStorage;
  }catch{
    alert("Storage blocked hai! Chrome normal mode me open karo.");
    return null;
  }
}

let store = getStorage();

let data = {doodh:[], pani:[]};

if(store){
  let saved = store.getItem("hisab");
  if(saved){
    try{
      data = JSON.parse(saved);
    }catch{}
  }
}

// ===== AUTO DATE =====
function today(){
  let d = new Date();
  return d.toISOString().split("T")[0];
}

document.getElementById("dDate").value = today();
document.getElementById("pDate").value = today();

// ===== SAVE =====
function save(){
  if(store){
    store.setItem("hisab", JSON.stringify(data));
  }
  render();
}

// ===== ADD =====
function add(type){
  let date = document.getElementById(type==='doodh'?'dDate':'pDate').value;
  let qty = document.getElementById(type==='doodh'?'dQty':'pQty').value;

  if(!date || !qty){
    alert("Sab fill karo");
    return;
  }

  data[type].push({date, qty});
  save();
}

// ===== DELETE =====
function del(type,i){
  data[type].splice(i,1);
  save();
}

// ===== RENDER =====
function render(){

  let dhtml="", phtml="";

  data.doodh.forEach((e,i)=>{
    dhtml += `<div class="item">${e.date} - ${e.qty}L 
    <span onclick="del('doodh',${i})">❌</span></div>`;
  });

  data.pani.forEach((e,i)=>{
    phtml += `<div class="item">${e.date} - ${e.qty}L 
    <span onclick="del('pani',${i})">❌</span></div>`;
  });

  document.getElementById("dList").innerHTML = dhtml;
  document.getElementById("pList").innerHTML = phtml;
}

// ===== EXPORT =====
function exportData(){
  let blob = new Blob([JSON.stringify(data)],{type:"application/json"});
  let a = document.createElement("a");
  a.href = URL.createObjectURL(blob);
  a.download = "hisab.json";
  a.click();
}

// ===== IMPORT =====
function importData(e){
  let file = e.target.files[0];
  let reader = new FileReader();

  reader.onload = function(ev){
    try{
      data = JSON.parse(ev.target.result);
      save();
    }catch{
      alert("File galat hai");
    }
  };

  reader.readAsText(file);
}

render();

</script>

</body>
</html>
